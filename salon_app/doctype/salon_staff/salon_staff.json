{
  "name": "Salon Staff",
  "doctype": "DocType",
  "module": "Salon App",
  "custom": 0,
  "autoname": "field:staff_name",
  "naming_rule": "By fieldname",
  "fields": [
    {
      "fieldname": "staff_name",
      "fieldtype": "Data",
      "label": "Staff Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "salon_type",
      "fieldtype": "Select",
      "label": "Works For",
      "options": "Men\nWomen\nUnisex",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "role",
      "fieldtype": "Select",
      "label": "Role",
      "options": "Barber\nStylist\nNail Tech\nSkin Therapist\nMakeup Artist\nManager",
      "in_list_view": 1
    },
    {
      "fieldname": "phone",
      "fieldtype": "Data",
      "label": "Phone",
      "reqd": 1
    },
    {
      "fieldname": "specialization",
      "fieldtype": "Data",
      "label": "Specialization"
    },
    {
      "fieldname": "experience_years",
      "fieldtype": "Int",
      "label": "Experience (Years)"
    },
    {
      "fieldname": "photo",
      "fieldtype": "Attach Image",
      "label": "Photo"
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Is Active",
      "default": "1"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Salon Owner",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Guest",
      "read": 1
    }
  ]
}