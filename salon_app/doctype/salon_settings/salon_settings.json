{
  "name": "Salon Settings",
  "doctype": "DocType",
  "module": "Salon App",
  "custom": 0,
  "issingle": 1,
  "fields": [
    {
      "fieldname": "salon_name",
      "fieldtype": "Data",
      "label": "Salon Name",
      "default": "Luminescent Atelier"
    },
    {
      "fieldname": "tagline",
      "fieldtype": "Data",
      "label": "Tagline"
    },
    {
      "fieldname": "phone",
      "fieldtype": "Data",
      "label": "Phone"
    },
    {
      "fieldname": "email",
      "fieldtype": "Data",
      "label": "Email"
    },
    {
      "fieldname": "address",
      "fieldtype": "Small Text",
      "label": "Address"
    },
    {
      "fieldname": "hours",
      "fieldtype": "Data",
      "label": "Working Hours",
      "default": "9 AM - 8 PM Daily"
    },
    {
      "fieldname": "upi_id",
      "fieldtype": "Data",
      "label": "UPI ID"
    },
    {
      "fieldname": "google_rating",
      "fieldtype": "Float",
      "label": "Google Rating",
      "default": "4.9"
    },
    {
      "fieldname": "total_clients",
      "fieldtype": "Int",
      "label": "Total Clients",
      "default": "500"
    },
    {
      "fieldname": "experience_years",
      "fieldtype": "Int",
      "label": "Experience Years",
      "default": "5"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1
    },
    {
      "role": "Salon Owner",
      "read": 1,
      "write": 1
    },
    {
      "role": "Guest",
      "read": 1
    }
  ]
}