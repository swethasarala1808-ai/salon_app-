      "label": "Full Address"
    },
    {
      "fieldname": "phone",
      "fieldtype": "Data",
      "label": "Phone",
      "reqd": 1
    },
    {
      "fieldname": "email",
      "fieldtype": "Data",
      "label": "Email"
    },
    {
      "fieldname": "manager",
      "fieldtype": "Data",
      "label": "Branch Manager"
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Is Active",
      "default": "1"
