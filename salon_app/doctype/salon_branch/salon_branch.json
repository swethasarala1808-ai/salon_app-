  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Salon Owner",
      "read": 1,
      "write": 1,
      "create": 1
    },
    {
      "role": "Guest",
      "read": 1
