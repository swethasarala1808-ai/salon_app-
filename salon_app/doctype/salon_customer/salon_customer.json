{
  "name": "Salon Customer",
  "doctype": "DocType",
  "module": "Salon App",
  "custom": 0,
  "autoname": "SCUST-.YYYY.-.#####",
  "fields": [
    {
      "fieldname": "full_name",
      "fieldtype": "Data",
      "label": "Full Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "phone",
      "fieldtype": "Data",
      "label": "Phone",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "email",
      "fieldtype": "Data",
      "label": "Email"
    },
    {
      "fieldname": "gender",
      "fieldtype": "Select",
      "label": "Gender",
      "options": "\nMale\nFemale\nOther",
      "in_list_view": 1
    },
    {
      "fieldname": "salon_type",
      "fieldtype": "Select",
      "label": "Preferred Salon",
      "options": "Men\nWomen\nUnisex",
      "in_list_view": 1
    },
    {
      "fieldname": "date_of_birth",
      "fieldtype": "Date",
      "label": "Date of Birth"
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Notes"
    },
    {
      "fieldname": "total_visits",
      "fieldtype": "Int",
      "label": "Total Visits",
      "default": "0"
    },
    {
      "fieldname": "loyalty_points",
      "fieldtype": "Int",
      "label": "Loyalty Points",
      "default": "0"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Salon Owner",
      "read": 1,
      "write": 1,
      "create": 1
    },
    {
      "role": "Guest",
      "read": 1,
      "write": 1,
      "create": 1
    }
  ]
}