{
  "name": "Salon Invoice",
  "doctype": "DocType",
  "module": "Salon App",
  "custom": 0,
  "autoname": "SINV-.YYYY.-.#####",
  "fields": [
    {
      "fieldname": "customer_name",
      "fieldtype": "Data",
      "label": "Customer Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "appointment",
      "fieldtype": "Data",
      "label": "Appointment ID",
      "in_list_view": 1
    },
    {
      "fieldname": "salon_type",
      "fieldtype": "Select",
      "label": "Salon Type",
      "options": "Men\nWomen\nUnisex",
      "in_list_view": 1
    },
    {
      "fieldname": "service",
      "fieldtype": "Data",
      "label": "Service",
      "in_list_view": 1
    },
    {
      "fieldname": "stylist",
      "fieldtype": "Data",
      "label": "Stylist"
    },
    {
      "fieldname": "invoice_date",
      "fieldtype": "Date",
      "label": "Invoice Date",
      "reqd": 1
    },
    {
      "fieldname": "subtotal",
      "fieldtype": "Currency",
      "label": "Subtotal"
    },
    {
      "fieldname": "discount",
      "fieldtype": "Currency",
      "label": "Discount",
      "default": "0"
    },
    {
      "fieldname": "grand_total",
      "fieldtype": "Currency",
      "label": "Grand Total",
      "in_list_view": 1
    },
    {
      "fieldname": "payment_status",
      "fieldtype": "Select",
      "label": "Payment Status",
      "options": "Unpaid\nPaid\nPartially Paid",
      "default": "Unpaid",
      "in_list_view": 1
    },
    {
      "fieldname": "payment_method",
      "fieldtype": "Select",
      "label": "Payment Method",
      "options": "\nUPI\nCash\nCard"
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Notes"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Salon Owner",
      "read": 1,
      "write": 1,
      "create": 1
    },
    {
      "role": "Guest",
      "read": 1,
      "write": 1,
      "create": 1
    }
  ]
}