{
  "name": "Salon Service",
  "doctype": "DocType",
  "module": "Salon App",
  "custom": 0,
  "autoname": "field:service_name",
  "naming_rule": "By fieldname",
  "fields": [
    {
      "fieldname": "service_name",
      "fieldtype": "Data",
      "label": "Service Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "salon_type",
      "fieldtype": "Select",
      "label": "Salon Type",
      "options": "Men\nWomen\nUnisex",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "category",
      "fieldtype": "Data",
      "label": "Category",
      "in_list_view": 1
    },
    {
      "fieldname": "price",
      "fieldtype": "Currency",
      "label": "Price",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "duration_minutes",
      "fieldtype": "Int",
      "label": "Duration (mins)",
      "default": "30"
    },
    {
      "fieldname": "description",
      "fieldtype": "Small Text",
      "label": "Description"
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Is Active",
      "default": "1"
    },
    {
      "fieldname": "branch",
      "fieldtype": "Link",
      "label": "Branch",
      "options": "Salon Branch",
      "in_list_view": 0
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Salon Owner",
      "read": 1,
      "write": 1,
      "create": 1
    },
    {
      "role": "Guest",
      "read": 1
    }
  ]
}