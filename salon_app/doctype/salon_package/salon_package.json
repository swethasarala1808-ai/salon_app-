{
  "name": "Salon Package",
  "doctype": "DocType",
  "module": "Salon App",
  "custom": 0,
  "autoname": "field:package_name",
  "naming_rule": "By fieldname",
  "fields": [
    {
      "fieldname": "package_name",
      "fieldtype": "Data",
      "label": "Package Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "salon_type",
      "fieldtype": "Select",
      "label": "Salon Type",
      "options": "Men\nWomen\nUnisex",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "price",
      "fieldtype": "Currency",
      "label": "Price",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "validity_days",
      "fieldtype": "Int",
      "label": "Validity (Days)"
    },
    {
      "fieldname": "discount_percent",
      "fieldtype": "Float",
      "label": "Discount %"
    },
    {
      "fieldname": "description",
      "fieldtype": "Small Text",
      "label": "Description"
    },
    {
      "fieldname": "services_included",
      "fieldtype": "Text",
      "label": "Services Included"
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Is Active",
      "default": "1"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Salon Owner",
      "read": 1,
      "write": 1,
      "create": 1
    },
    {
      "role": "Guest",
      "read": 1
    }
  ]
}