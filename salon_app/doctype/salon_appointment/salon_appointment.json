{
  "name": "Salon Appointment",
  "doctype": "DocType",
  "module": "Salon App",
  "custom": 0,
  "autoname": "SAPT-.YYYY.-.#####",
  "track_changes": 1,
  "fields": [
    {
      "fieldname": "customer_name",
      "fieldtype": "Data",
      "label": "Customer Name",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "customer_phone",
      "fieldtype": "Data",
      "label": "Phone",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "salon_type",
      "fieldtype": "Select",
      "label": "Salon Type",
      "options": "Men\nWomen\nUnisex",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "service",
      "fieldtype": "Link",
      "label": "Service",
      "options": "Salon Service",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "stylist",
      "fieldtype": "Link",
      "label": "Stylist",
      "options": "Salon Staff"
    },
    {
      "fieldname": "appointment_date",
      "fieldtype": "Date",
      "label": "Appointment Date",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "appointment_time",
      "fieldtype": "Time",
      "label": "Appointment Time",
      "reqd": 1
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Booked\nConfirmed\nIn Progress\nCompleted\nCancelled",
      "default": "Booked",
      "in_list_view": 1
    },
    {
      "fieldname": "notes",
      "fieldtype": "Small Text",
      "label": "Notes"
    },
    {
      "fieldname": "whatsapp_sent",
      "fieldtype": "Check",
      "label": "WhatsApp Sent"
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Salon Owner",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Guest",
      "read": 1,
      "write": 1,
      "create": 1
    }
  ]
}